---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ExternalLink from '../components/ExternalLink.astro';

// type Props = CollectionEntry<'projects'>['data'];

interface Props {
	project: {
		title: string;
		createdDate: string;
		description: string;
		status?: string;
		tags?: string[];
		repoUrl?: string;
		liveUrl?: string;
		heroImage?: string;
		heroAlt?: string;
	};
	updates: Array<{
		id: string;
		data: {
			title: string;
			pubDate: Date;
		};
	}>;
}

const { project, updates } = Astro.props;

const { title, description, createdDate, status, tags, repoUrl, liveUrl, heroImage, heroAlt } =
	project;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			article {
				font-size: 125%;
				text-wrap-style: pretty;
				h2,
				h3 {
					margin-top: 1.5em;
					border-left-width: 2em;
					border-left-color: var(--accent-color-1);
					border-left-style: solid;
					padding-left: 0.5em;
				}

				h3 {
					border-left-width: 1em;
				}

				h2:nth-of-type(2),
				h3:nth-of-type(2) {
					border-left-color: var(--accent-color-2);
				}

				h2:nth-of-type(3),
				h3:nth-of-type(3) {
					border-left-color: var(--accent-color-3);
				}

				.heroImage {
					margin-top: 1em;
				}
			}

			.project-meta {
				margin-bottom: 1em;
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				align-items: baseline;
			}

			.status {
				font-size: 0.8em;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				padding: 0.2em 0.6em;
				border-radius: 2px;
				background: var(--background-accent);
			}

			.status.active {
				border-left: 3px solid var(--accent-color-1);
			}
			.status.archived {
				border-left: 3px solid var(--accent-color-4);
			}
			.status.planned {
				border-left: 3px solid var(--accent-color-3);
			}

			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-top: 0.75em;
			}

			.tag {
				font-size: 0.8em;
				padding: 0.2em 0.5em;
				background: var(--background-accent);
				border-radius: 2px;
			}

			.project-links {
				display: flex;
				gap: 1rem;
				margin-top: 0.75em;
			}

			.blog-navigation {
				margin-top: 2rem;
				text-align: center;
			}
		</style>
	</head>

	<body>
		<div class="page">
			<Header />
			<main>
				<article>
					{
						heroImage && (
							<img class="heroImage" width={720} height={360} src={heroImage} alt={heroAlt} />
						)
					}
					<h1 class="title">{title}</h1>

					<div class="project-meta">
						{status && <span class={`status ${status}`}>{status}</span>}
						<FormattedDate date={createdDate} />
					</div>

					{
						tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
						)
					}

					{
						(repoUrl || liveUrl) && (
							<div class="project-links">
								{repoUrl && <ExternalLink href={repoUrl}>Repository</ExternalLink>}
								{liveUrl && <ExternalLink href={liveUrl}>Live site</ExternalLink>}
							</div>
						)
					}

					<hr />
					<slot />

					{
						updates.length > 0 && (
							<section class="project-updates">
								<h2>Project Updates</h2>
								<ul>
									{updates.map((update) => (
										<li>
											<FormattedDate date={update.data.pubDate} />
											<a href={`/blog/${update.id}`}>{update.data.title}</a>
										</li>
									))}
								</ul>
							</section>
						)
					}
				</article>

				<div class="blog-navigation">
					<a href="/projects">Back to projects</a> | <a href="/">Back to home</a>
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>
